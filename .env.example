# JWT Security
JWT_SECRET=your-super-secret-key-change-this-in-production

# Spring Datasource Configuration (Local defaults shown, replace with Cloud DB details like Neon/Supabase)
# Local Docker defaults:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/seveneleven
# Local host defaults (running jar directly):
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/seveneleven
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/seveneleven
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
