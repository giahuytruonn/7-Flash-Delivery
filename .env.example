# JWT Security
JWT_SECRET=your-super-secret-key-change-this-in-production

# PostgreSQL Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=seveneleven
DB_USER=postgres
DB_PASSWORD=postgres

# Paste your full cloud PostgreSQL database JDBC URL here if using a cloud DB (e.g. Supabase, Neon, AWS RDS)
# Example: jdbc:postgresql://ep-cool-snowflake-1234.us-east-2.aws.neon.tech/seveneleven?sslmode=require
CLOUD_DB_URL=

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
